    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase": "^12.14.0",
    "firebase-admin": "^12.7.0",
    "framer-motion": "^12.38.0",
    "html5-qrcode": "^2.3.8",
    "http-proxy-middleware": "^4.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nodemailer": "^9.0.3",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
